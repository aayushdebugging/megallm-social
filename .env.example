# AI Generation (use one or both)
OPENAI_API_KEY=

# MegaLLM gateway (used by tools/devto-assistant, tools/reddit-assistant, pipeline)
# If you see 401 AUTH_FAILED / "API key is revoked", mint a new key in the MegaLLM dashboard.
MEGALLM_API_KEY=
MEGALLM_BASE_URL=https://ai.megallm.io/v1
MODEL=

# Hacker News assistant (tools/hackernews-assistant) — optional; uses MegaLLM above for drafting
# HN_LIST=top
# HN_ASSISTANT_PORT=3458

# Bluesky assistant (tools/bluesky-assistant) — public API for fetch; MegaLLM for drafts
# BSKY_FEED_URI=at://did:plc:z72i7hdynmk6r22z27h6tvur/app.bsky.feed.generator/whats-hot
# BSKY_MAX_POSTS=35
# BSKY_MIN_LIKES=15
# BSKY_PUBLIC_API=https://public.api.bsky.app

# Unified dashboard — Reddit, Dev.to, HN, Bluesky (`npm run assistant:unified` from repo root)
# UNIFIED_ASSISTANT_USER=
# UNIFIED_ASSISTANT_PASSWORD=
# UNIFIED_SESSION_SECRET=change-me-in-production
# UNIFIED_ASSISTANT_PORT=3500

# Web Scraping
FIRECRAWL_API_KEY=

# SERP Tracking (free tier: 2500 queries/mo)
SERPER_API_KEY=

# Social Metrics (read-only, ~$0.15/1K tweets)
TWITTERAPI_IO_KEY=

# Dev.to (free API)
DEVTO_API_KEY=
DEVTO_USERNAME=
DEVTO_PUBLISH_IMMEDIATELY=true
DEVTO_DEFAULT_TAGS=megallm,viral,trending

# Google Search Console
GOOGLE_SERVICE_ACCOUNT_JSON=
GSC_SITE_URL=https://megallm.io

# Vercel Cron Auth
CRON_SECRET=

# Pipeline Control
PIPELINE_ENABLED=true
PIPELINE_DRY_RUN=false
